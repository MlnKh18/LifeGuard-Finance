## ─── STEP 8: FVS CALCULATOR & DASHBOARD ───

Mesin FVS menghitung parameter kerentanan finansial secara berbobot dari 0 (Kritis) hingga 100 (Aman).

### 1. FvsCalculator Service
```dart
import '../../domain/entities/family_finance_profile.dart';
import '../models/fvs_score_model.dart';

class FvsCalculator {
  static FvsScoreModel calculate(FamilyFinanceProfile profile) {
    // S1: Kestabilan Pendapatan (Pendapatan Tetap vs Tidak Tetap)
    double s1 = (profile.fixedIncome >= profile.variableIncome) ? 100.0 : 60.0;

    // S2: Rasio Pengeluaran terhadap Pendapatan Total
    double totalIncome = profile.totalIncome;
    double expenseRatio = totalIncome > 0 ? (profile.routineExpense / totalIncome) : 1.0;
    double s2 = expenseRatio <= 0.50 ? 100.0 : expenseRatio <= 0.70 ? 80.0 : expenseRatio <= 0.90 ? 50.0 : 20.0;

    // S3: Kesiapan Dana Darurat (Cover Bulan Pengeluaran)
    double emergencyMonths = profile.routineExpense > 0 ? (profile.liquidSavings / profile.routineExpense) : 0.0;
    double s3 = emergencyMonths >= 6.0 ? 100.0 : emergencyMonths >= 3.0 ? 75.0 : emergencyMonths >= 1.0 ? 40.0 : 10.0;

    // S4: Debt Burden Ratio (DBR)
    double dbr = totalIncome > 0 ? (profile.monthlyDebtPayment / totalIncome) : 0.0;
    double s4 = dbr == 0 ? 100.0 : dbr <= 0.30 ? 80.0 : dbr <= 0.40 ? 50.0 : dbr <= 0.50 ? 30.0 : 10.0;

    // S5: Beban Tanggungan
    double s5 = profile.dependentsCount == 0 ? 100.0 : profile.dependentsCount <= 2 ? 80.0 : profile.dependentsCount <= 4 ? 50.0 : 25.0;

    // S6: Proteksi Jaminan Asuransi
    double s6 = 10.0;
    if (profile.hasBpjs && profile.hasAdditionalInsurance) {
      s6 = 100.0;
    } else if (profile.hasBpjs) {
      s6 = 80.0;
    } else if (profile.hasAdditionalInsurance) {
      s6 = 40.0;
    }

    // S7: Daya Serap Guncangan Sintetis
    double s7 = (s3 * 0.4) + (s2 * 0.3) + (s4 * 0.3);
    // Penalti 50% jika mengalami defisit anggaran bulanan
    if (profile.routineExpense + profile.monthlyDebtPayment > totalIncome) {
      s7 = s7 * 0.5;
    }

    // Formula Bobot Akhir
    double totalFvs = (0.20 * s1) + (0.15 * s2) + (0.20 * s3) + (0.20 * s4) + (0.10 * s5) + (0.10 * s6) + (0.05 * s7);

    return FvsScoreModel(
      totalScore: totalFvs.round(),
      s1: s1.round(),
      s2: s2.round(),
      s3: s3.round(),
      s4: s4.round(),
      s5: s5.round(),
      s6: s6.round(),
      s7: s7.round(),
      calculatedAt: DateTime.now(),
    );
  }

  static String getCategory(int score) {
    if (score >= 80) return 'Aman';
    if (score >= 60) return 'Waspada';
    if (score >= 40) return 'Rentan';
    return 'Kritis';
  }
}
```

